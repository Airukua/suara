# Ignore generated artifacts and local caches
**/artifacts/
**/cache/
**/cleaned/
**/tokens/

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling and test caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage and build outputs
.coverage
.coverage.*
htmlcov/
build/
dist/
*.egg-info/

# Notebook and editor junk
.ipynb_checkpoints/
.DS_Store
Thumbs.db
*.log
*.tmp
